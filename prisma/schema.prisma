generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model RawEvent {
  id        String   @id @default(uuid())
  eventId   String
  type      String
  userId    String?
  timestamp DateTime
  props     Json
  createdAt DateTime @default(now())

  @@index([eventId])
  @@index([type])
  @@index([timestamp])
}